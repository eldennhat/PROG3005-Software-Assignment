@model BookViewModel

@{
    ViewBag.Title = "Book Details";
}

<h3 class="mb-4">Book Details</h3>

<div class="card" style="max-width: 500px">
    <div class="card-body">
        <table class="table">
            <tr>
                <th>ID</th>
                <td>@Model.Id</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>@Model.Name</td>
            </tr>
            <tr>
                <th>Price</th>
                <td>$@Model.Price</td>
            </tr>
        </table>

        <a asp-controller="Book" asp-action="Index" class="btn btn-secondary" style="text-align: center;">
            Return
        </a>
    </div>
</div>
